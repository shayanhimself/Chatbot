root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
ktlint_code_style = ktlint_official
max_line_length = 100

# Composables are PascalCase by convention, which ktlint's function-naming rule
# otherwise rejects.
ktlint_function_naming_ignore_when_annotated_with = Composable

# A trailing comma is what pins an argument list open — without these, ktlint
# strips it and the list is free to collapse back onto one line.
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
